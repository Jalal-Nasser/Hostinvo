APP_NAME=Hostinvo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hostinvo
DB_USERNAME=hostinvo
DB_PASSWORD=hostinvo
DB_SCHEMA=public
DB_SSLMODE=prefer

SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE=hostinvo_session
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8080,127.0.0.1,127.0.0.1:3000,127.0.0.1:8080,::1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@hostinvo.test"
MAIL_FROM_NAME="${APP_NAME}"

HOSTINVO_SUPPORTED_LOCALES=en,ar
HOSTINVO_DEFAULT_CURRENCY=USD
HOSTINVO_PANEL_DRIVERS=cpanel,plesk

PAYMENTS_STRIPE_ENABLED=false
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASE_URL=https://api.stripe.com

PAYMENTS_PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_LIVE_BASE_URL=https://api-m.paypal.com
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300

SUPER_ADMIN_NAME="Hostinvo Super Admin"
SUPER_ADMIN_EMAIL=admin@hostinvo.test
SUPER_ADMIN_PASSWORD=ChangeMe123!

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
