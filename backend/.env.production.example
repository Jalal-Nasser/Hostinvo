APP_NAME=Hostinvo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api.hostinvo.example
FRONTEND_URL=https://app.hostinvo.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=production
LOG_STACK=json_daily,stderr_json
LOG_PRODUCTION_STACK=json_daily,stderr_json
LOG_LEVEL=info
LOG_DAILY_DAYS=30

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hostinvo
DB_USERNAME=hostinvo
DB_PASSWORD=change-this
DB_SCHEMA=public
DB_SSLMODE=prefer

SESSION_DRIVER=tenant-database
SESSION_CONNECTION=pgsql
SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_COOKIE=hostinvo_session
SESSION_PATH=/
SESSION_DOMAIN=.hostinvo.example
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_BLOCK_FOR=5
REDIS_QUEUE_RETRY_AFTER=120
QUEUE_TIER_CRITICAL=critical
QUEUE_TIER_DEFAULT=default
QUEUE_TIER_LOW=low
QUEUE_TIER_CRITICAL_TRIES=3
QUEUE_TIER_DEFAULT_TRIES=3
QUEUE_TIER_LOW_TRIES=2
QUEUE_WORKER_SLEEP=3
QUEUE_WORKER_TIMEOUT=120
QUEUE_WORKER_MAX_TIME=3600
QUEUE_WORKER_CRITICAL_PROCS=2
QUEUE_WORKER_DEFAULT_PROCS=2
QUEUE_WORKER_LOW_PROCS=1

CACHE_STORE=redis
CACHE_PREFIX=hostinvo_prod

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=change-this
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

SANCTUM_STATEFUL_DOMAINS=app.hostinvo.example
CORS_ALLOWED_ORIGINS=https://app.hostinvo.example

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@hostinvo.example"
MAIL_FROM_NAME="${APP_NAME}"

HOSTINVO_SUPPORTED_LOCALES=en,ar
HOSTINVO_DEFAULT_CURRENCY=USD
HOSTINVO_PANEL_DRIVERS=cpanel,plesk
HOSTINVO_DEFAULT_PER_PAGE=15
HOSTINVO_MAX_PER_PAGE=100
HOSTINVO_CACHE_TENANT_SETTINGS_TTL=300
HOSTINVO_CACHE_CATALOG_SELECTION_TTL=300
HOSTINVO_PROVISIONING_QUEUE=critical
HOSTINVO_CPANEL_DEFAULT_PORT=2087
HOSTINVO_CPANEL_TIMEOUT=30
HOSTINVO_CPANEL_CONNECT_TIMEOUT=10
HOSTINVO_CPANEL_RETRY_TIMES=3
HOSTINVO_CPANEL_RETRY_SLEEP_MS=500
HOSTINVO_PLESK_DEFAULT_PORT=8443
HOSTINVO_PLESK_TIMEOUT=30
HOSTINVO_PLESK_CONNECT_TIMEOUT=10
HOSTINVO_PLESK_RETRY_TIMES=3
HOSTINVO_PLESK_RETRY_SLEEP_MS=500

PAYMENTS_STRIPE_ENABLED=true
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASE_URL=https://api.stripe.com

PAYMENTS_PAYPAL_ENABLED=true
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=live
PAYPAL_SANDBOX_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_LIVE_BASE_URL=https://api-m.paypal.com
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300

MONITORING_METRICS_TOKEN=change-this-token
MONITORING_METRICS_WINDOW_MINUTES=5
MONITORING_METRICS_RETENTION_SECONDS=172800
MONITORING_ALERT_QUEUE_BACKLOG_THRESHOLD=500
MONITORING_ALERT_JOB_FAILURE_RATE_THRESHOLD=10
MONITORING_ALERT_LOG_CHANNEL=production
MONITORING_ALERT_WEBHOOK_URL=
