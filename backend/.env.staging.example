APP_NAME=Hostinvo
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api-staging.hostinvo.example
FRONTEND_URL=https://staging.hostinvo.example
STAGING_APP_HTTP_PORT=8081

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=production
LOG_STACK=json_daily,stderr_json
LOG_PRODUCTION_STACK=json_daily,stderr_json
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hostinvo_staging
DB_USERNAME=hostinvo
DB_PASSWORD=change-this
DB_SCHEMA=public
DB_SSLMODE=prefer
STAGING_POSTGRES_DB=hostinvo_staging
STAGING_POSTGRES_USER=hostinvo
STAGING_POSTGRES_PASSWORD=change-this

SESSION_DRIVER=tenant-database
SESSION_CONNECTION=pgsql
SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_COOKIE=hostinvo_staging_session
SESSION_PATH=/
SESSION_DOMAIN=.staging.hostinvo.example
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE_BLOCK_FOR=5
REDIS_QUEUE_RETRY_AFTER=120
QUEUE_TIER_CRITICAL=critical
QUEUE_TIER_DEFAULT=default
QUEUE_TIER_LOW=low
QUEUE_TIER_CRITICAL_TRIES=3
QUEUE_TIER_DEFAULT_TRIES=3
QUEUE_TIER_LOW_TRIES=2
QUEUE_WORKER_SLEEP=3
QUEUE_WORKER_TIMEOUT=120
QUEUE_WORKER_MAX_TIME=3600
QUEUE_WORKER_CRITICAL_PROCS=1
QUEUE_WORKER_DEFAULT_PROCS=1
QUEUE_WORKER_LOW_PROCS=1

CACHE_STORE=redis
CACHE_PREFIX=hostinvo_staging

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=change-this
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

SANCTUM_STATEFUL_DOMAINS=staging.hostinvo.example
CORS_ALLOWED_ORIGINS=https://staging.hostinvo.example

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@staging.hostinvo.example"
MAIL_FROM_NAME="[STAGING] Hostinvo"

HOSTINVO_SUPPORTED_LOCALES=en,ar
HOSTINVO_DEFAULT_CURRENCY=USD
HOSTINVO_PANEL_DRIVERS=cpanel,plesk
HOSTINVO_PROVISIONING_QUEUE=critical

# Staging safety rules: real gateways are disabled.
PAYMENTS_STRIPE_ENABLED=false
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASE_URL=https://api.stripe.com

PAYMENTS_PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
PAYPAL_SANDBOX_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_LIVE_BASE_URL=https://api-m.paypal.com
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300

MONITORING_METRICS_TOKEN=change-this-token
MONITORING_METRICS_WINDOW_MINUTES=5
MONITORING_METRICS_RETENTION_SECONDS=172800
MONITORING_ALERT_QUEUE_BACKLOG_THRESHOLD=250
MONITORING_ALERT_JOB_FAILURE_RATE_THRESHOLD=10
MONITORING_ALERT_LOG_CHANNEL=production
MONITORING_ALERT_WEBHOOK_URL=
